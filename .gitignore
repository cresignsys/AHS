#################################################
# Abey Hosting Server (AHS)
# Git Ignore
#################################################

############################
# Runtime Logs
############################

logs/
*.log

############################
# Cache
############################

cache/
tmp/

############################
# Backups
############################

backups/
*.zip
*.tar
*.tar.gz
*.gz

############################
# Website Data
############################

sites/*.conf

############################
# Temporary Files
############################

*.tmp
*.temp
*.pid
*.lock
*.swp
*.swo
*~

############################
# Shell History
############################

.history

############################
# Test Files
############################

test-*.sh

############################
# Editor
############################

.vscode/
.idea/

############################
# Linux
############################

.DS_Store
Thumbs.db

############################
# SSL Certificates
############################

*.pem
*.key
*.csr
*.crt

############################
# Environment Files
############################

.env
.env.*

############################
# MySQL Dumps
############################

*.sql

############################
# WP-CLI Cache
############################

.wp-cli/

############################
# Composer
############################

vendor/

############################
# Node
############################

node_modules/

############################
# Python
############################

__pycache__/
*.pyc

############################
# Generated Website Files
############################

data/
